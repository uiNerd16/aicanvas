# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit secrets.

# ─────────────────────────────────────────────────────────────────────
# PostHog — registry usage analytics (used by proxy.ts)
# ─────────────────────────────────────────────────────────────────────
# Sign up at https://posthog.com (free tier: 1M events/month).
# Create a project, then copy the "Project API Key" from Project Settings.
# This is the public/ingest key — safe in client code, not a secret admin key.
POSTHOG_KEY=

# PostHog cloud region. US is the default; use the EU URL if your project
# was created in the EU region.
#   US: https://us.i.posthog.com
#   EU: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────────
# Google Search Console tooling — used by `npm run gsc:audit` / `gsc:submit`
# ─────────────────────────────────────────────────────────────────────
# Absolute path to the GCP service-account JSON key.
# Recommended location: ~/.config/gcloud/aicanvas-gsc.json (chmod 600).
# The service account must be added as Owner on the GSC property.
# Setup steps live in scripts/gsc-audit.ts header comment.
GOOGLE_APPLICATION_CREDENTIALS=

# Public site URL — used to fetch /sitemap.xml.
GSC_SITE_URL=https://aicanvas.me

# GSC property identifier — must match the property as registered in Search Console:
#   - Domain property (DNS-verified):  sc-domain:aicanvas.me
#   - URL-prefix property:             https://aicanvas.me/
# If unset, falls back to GSC_SITE_URL.
GSC_PROPERTY=sc-domain:aicanvas.me

# ─────────────────────────────────────────────────────────────────────
# Supabase — auth + Postgres for user accounts (feat/user-accounts branch)
# ─────────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com (free: 50k MAU, 500MB Postgres).
# In Supabase: Settings → API Keys → "Publishable and secret API keys" tab.
# Copy ONLY the "Publishable key" row (the `sb_publishable_*` one). Both values
# below are PUBLIC by design — they ship in every browser bundle. Row Level
# Security (RLS) policies on your tables enforce data access; key secrecy does
# not. Setting in Vercel: Project → Settings → Environment Variables → Preview.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# DO NOT add the secret key (sb_secret_*) here, in .env.local, or anywhere on
# a developer machine. It bypasses RLS — full read/write to every table. Phase
# 1 of user-accounts does NOT use it. If a future phase needs admin operations,
# set it as a Vercel server-side env var only (never in a committed file, never
# in a .env.local copy on disk, never pasted into chat).

# ImageKit private key (private_*) — used only by scripts/screenshot.mjs to
# upload component screenshots. Server/CLI-only secret. Put the real value in
# .env.local, never here. Rotate in the ImageKit dashboard if ever exposed.
IMAGEKIT_PRIVATE_KEY=

# Master switch for all premium/subscription UI. 'true' to show it.
# Off (default) = today's fully-free site. This is also the kill switch.
NEXT_PUBLIC_PREMIUM_ENABLED=false

# Server-only Supabase secret key (sb_secret_*). Set ONLY as a Vercel server
# env var — never NEXT_PUBLIC_, never in client code, never in .env.local on a
# dev machine. Bypasses RLS; used by token validation + the Paddle webhook.
SUPABASE_SECRET_KEY=

# Paddle Billing webhook signing secret (Paddle dashboard -> Notifications).
# The webhook fails closed (503) when this is unset.
PADDLE_WEBHOOK_SECRET=

# Salt for hashing anonymous IPs in the usage counter (server-only, any random
# string). REQUIRED in enforce mode — metering fails closed without it.
# The effective key is HMAC(USAGE_IP_SALT, utcDay) — per-day, unlinkable.
USAGE_IP_SALT=
# Registry gate mode: off | permissive | enforce. Keep permissive until launch;
# flipping back to permissive is the kill switch.
# NOTE on flipping (Vercel): env changes take effect on the NEXT DEPLOY — the
# component pages are statically prerendered, so the redeploy is what swaps
# the HTML between source-embedded and fetch-on-demand. Flip the var, then
# redeploy; also purge the CDN cache when flipping TO enforce.
# Enforce additionally requires NEXT_PUBLIC_PREMIUM_ENABLED=true (the routes
# refuse to enforce without the premium UI and fall back to permissive,
# loudly — otherwise blocked users would have no upgrade path).
REGISTRY_ENFORCEMENT=permissive

# Paddle Billing (client-safe — these are public by design). Fill from the
# Paddle dashboard once the product + prices exist. Checkout is a no-op until set.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox            # 'sandbox' | 'production'
NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=pri_xxx
NEXT_PUBLIC_PADDLE_PRICE_YEARLY=pri_yyy
# Server-only Paddle API key (verifies checkout transactions + opens the
# customer portal). Set ONLY as a Vercel server env var.
PADDLE_API_KEY=
PADDLE_ENV=sandbox                        # 'sandbox' | 'production' (server side)
