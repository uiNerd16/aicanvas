# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit secrets.

# ─────────────────────────────────────────────────────────────────────
# PostHog — registry usage analytics (used by proxy.ts)
# ─────────────────────────────────────────────────────────────────────
# Sign up at https://posthog.com (free tier: 1M events/month).
# Create a project, then copy the "Project API Key" from Project Settings.
# This is the public/ingest key — safe in client code, not a secret admin key.
POSTHOG_KEY=

# PostHog cloud region. US is the default; use the EU URL if your project
# was created in the EU region.
#   US: https://us.i.posthog.com
#   EU: https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────────
# Google Search Console tooling — used by `npm run gsc:audit` / `gsc:submit`
# ─────────────────────────────────────────────────────────────────────
# Absolute path to the GCP service-account JSON key.
# Recommended location: ~/.config/gcloud/aicanvas-gsc.json (chmod 600).
# The service account must be added as Owner on the GSC property.
# Setup steps live in scripts/gsc-audit.ts header comment.
GOOGLE_APPLICATION_CREDENTIALS=

# Public site URL — used to fetch /sitemap.xml.
GSC_SITE_URL=https://aicanvas.me

# GSC property identifier — must match the property as registered in Search Console:
#   - Domain property (DNS-verified):  sc-domain:aicanvas.me
#   - URL-prefix property:             https://aicanvas.me/
# If unset, falls back to GSC_SITE_URL.
GSC_PROPERTY=sc-domain:aicanvas.me

# ─────────────────────────────────────────────────────────────────────
# Supabase — auth + Postgres for user accounts (feat/user-accounts branch)
# ─────────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com (free: 50k MAU, 500MB Postgres).
# In Supabase: Settings → API Keys → "Publishable and secret API keys" tab.
# Copy ONLY the "Publishable key" row (the `sb_publishable_*` one). Both values
# below are PUBLIC by design — they ship in every browser bundle. Row Level
# Security (RLS) policies on your tables enforce data access; key secrecy does
# not. Setting in Vercel: Project → Settings → Environment Variables → Preview.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# DO NOT add the secret key (sb_secret_*) here, in .env.local, or anywhere on
# a developer machine. It bypasses RLS — full read/write to every table. Phase
# 1 of user-accounts does NOT use it. If a future phase needs admin operations,
# set it as a Vercel server-side env var only (never in a committed file, never
# in a .env.local copy on disk, never pasted into chat).
