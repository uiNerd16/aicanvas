# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
.screenshots-tmp/
/public/screenshots/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/

# superpowers brainstorm session files
.superpowers/

# auto-generated (rebuilt on every dev/build)
app/lib/component-codes.generated.ts
/public/r/

# business strategy (private — never pushed to GitHub)
/business-strategy/

# PUFI inspector (local-only dev tool — type "pufi" to toggle)
/public/pufi.js

# KOKO drawing tool (local-only dev tool — type "koko" to toggle)
/public/koko.js

# GSC tooling outputs (audit reports, submission logs)
/scripts/gsc-output/*
!/scripts/gsc-output/.gitkeep

# studio prototype (local-only — see "Studio prototype" memory)
/app/tune/
scripts/sync-output/
